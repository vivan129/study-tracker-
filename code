<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IGCSE Study OS — Vivan</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080c14;
    --surface: #0d1420;
    --surface2: #111b2e;
    --border: #1a2540;
    --blue: #3b82f6;
    --blue2: #60a5fa;
    --cyan: #22d3ee;
    --green: #4ade80;
    --yellow: #facc15;
    --red: #f87171;
    --orange: #fb923c;
    --text: #e2e8f0;
    --muted: #64748b;
    --mono: 'Space Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: 220px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }

  .sidebar-header {
    padding: 20px 16px 12px;
    border-bottom: 1px solid var(--border);
  }

  .sidebar-header .logo {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .sidebar-header h1 {
    font-size: 15px;
    font-weight: 800;
    color: var(--text);
    line-height: 1.2;
  }

  .sidebar-subjects {
    flex: 1;
    overflow-y: auto;
    padding: 12px 10px;
  }

  .sidebar-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    padding: 4px 6px 8px;
    font-family: var(--mono);
  }

  .subject-btn {
    width: 100%;
    background: none;
    border: none;
    padding: 10px 10px;
    border-radius: 8px;
    color: var(--muted);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  .subject-btn:hover {
    background: var(--surface2);
    color: var(--text);
  }

  .subject-btn.active {
    background: linear-gradient(135deg, #1d3461, #1e3a5f);
    color: var(--blue2);
    border: 1px solid #2a4a7f;
  }

  .subject-btn .sub-timer-badge {
    font-family: var(--mono);
    font-size: 10px;
    background: #1a2540;
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--muted);
  }

  .subject-btn.active .sub-timer-badge {
    background: #1e3a6e;
    color: var(--blue2);
  }

  .subject-btn.running .sub-timer-badge {
    color: var(--green);
    animation: blink 1s infinite;
  }

  .subject-btn .weak-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--orange);
    display: inline-block;
    margin-right: 6px;
    flex-shrink: 0;
  }

  .subject-btn .sub-name {
    flex: 1;
    display: flex;
    align-items: center;
  }

  /* ─── MAIN ─── */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .topbar {
    padding: 14px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topbar-subject {
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
  }

  .topbar-badge {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    background: #1a2540;
    color: var(--muted);
    letter-spacing: 1px;
  }

  .topbar-badge.weak {
    background: #2a1a0a;
    color: var(--orange);
  }

  .topbar-right {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
  }

  .content {
    flex: 1;
    padding: 20px 24px;
    overflow-y: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 16px;
    align-content: start;
  }

  /* ─── CARDS ─── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover::before { opacity: 1; }

  .card-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    font-family: var(--mono);
    margin-bottom: 12px;
  }

  /* ─── TIMER CARD ─── */
  .timer-card {
    grid-column: 1 / 2;
  }

  .timer-display {
    font-family: var(--mono);
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -2px;
    color: var(--text);
    line-height: 1;
    margin-bottom: 4px;
    transition: color 0.3s;
  }

  .timer-display.running { color: var(--green); }
  .timer-display.paused { color: var(--yellow); }
  .timer-display.done { color: var(--cyan); }

  .timer-progress-bar {
    width: 100%;
    height: 4px;
    background: var(--surface2);
    border-radius: 2px;
    margin: 8px 0 14px;
    overflow: hidden;
  }

  .timer-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--blue), var(--cyan));
    border-radius: 2px;
    width: 0%;
    transition: width 1s linear;
  }

  .timer-progress-fill.running {
    background: linear-gradient(90deg, var(--green), var(--cyan));
  }

  .timer-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .timer-input {
    width: 70px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    padding: 8px 10px;
    outline: none;
    transition: border-color 0.2s;
  }

  .timer-input:focus { border-color: var(--blue); }

  .timer-input-label {
    font-size: 12px;
    color: var(--muted);
  }

  .btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    cursor: pointer;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn:hover { border-color: var(--blue); color: var(--blue2); }

  .btn-primary {
    background: var(--blue);
    border-color: var(--blue);
    color: white;
  }

  .btn-primary:hover {
    background: #2563eb;
    border-color: #2563eb;
    color: white;
  }

  .btn-danger {
    border-color: #3a1a1a;
    color: var(--red);
  }

  .btn-danger:hover {
    background: #2a0e0e;
    border-color: var(--red);
  }

  .timer-stats {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }

  .timer-stat {
    text-align: center;
  }

  .timer-stat-val {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--blue2);
  }

  .timer-stat-lbl {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  /* ─── AI CARD ─── */
  .ai-card {
    grid-column: 2 / 3;
  }

  .ai-content {
    font-size: 13px;
    line-height: 1.8;
    color: var(--text);
  }

  .ai-topic {
    display: inline-block;
    background: linear-gradient(135deg, #1d3461, #0f2040);
    border: 1px solid #2a4a7f;
    color: var(--blue2);
    padding: 6px 12px;
    border-radius: 6px;
    font-family: var(--mono);
    font-size: 12px;
    margin: 6px 0;
  }

  .ai-warning {
    background: #1a0e00;
    border: 1px solid #3a2000;
    color: var(--orange);
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 12px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-tip {
    background: var(--surface2);
    border-left: 3px solid var(--cyan);
    padding: 8px 12px;
    border-radius: 0 6px 6px 0;
    font-size: 12px;
    color: #94a3b8;
    margin-top: 8px;
  }

  /* ─── CHART CARD ─── */
  .chart-card {
    grid-column: 1 / 2;
  }

  /* ─── HEATMAP CARD ─── */
  .heatmap-card {
    grid-column: 2 / 3;
  }

  .heatmap {
    display: grid;
    grid-template-columns: repeat(14, 1fr);
    gap: 4px;
    margin-top: 4px;
  }

  .hm-square {
    aspect-ratio: 1;
    border-radius: 3px;
    background: var(--surface2);
    cursor: pointer;
    transition: transform 0.2s;
    position: relative;
  }

  .hm-square:hover { transform: scale(1.3); z-index: 10; }

  .hm-0 { background: #0d1420; border: 1px solid #1a2540; }
  .hm-1 { background: #1e3a5f; }
  .hm-2 { background: #1d4ed8; }
  .hm-3 { background: #2563eb; }
  .hm-4 { background: var(--cyan); }

  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    font-size: 10px;
    color: var(--muted);
    font-family: var(--mono);
  }

  .heatmap-legend .sq {
    width: 10px; height: 10px;
    border-radius: 2px;
  }

  /* ─── TOAST ─── */
  .toast-container {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .toast {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--text);
    animation: slideIn 0.3s ease, fadeOut 0.3s ease 3s forwards;
    max-width: 280px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }

  .toast.success { border-color: var(--green); }
  .toast.info { border-color: var(--blue); }
  .toast.warning { border-color: var(--orange); }

  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes fadeOut {
    to { opacity: 0; transform: translateX(100%); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .no-select { user-select: none; }

  /* ─── EMPTY STATE ─── */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
  }

  .empty-state .big {
    font-size: 48px;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-size: 14px;
    line-height: 1.6;
  }

  /* tooltip */
  .hm-square[title]:hover::after {
    content: attr(title);
    position: absolute;
    bottom: 130%;
    left: 50%;
    transform: translateX(-50%);
    background: #1e293b;
    color: var(--text);
    font-family: var(--mono);
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
    border: 1px solid var(--border);
    z-index: 100;
  }
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sidebar-header">
    <div class="logo">Study OS</div>
    <h1>Vivan's<br>IGCSE Dashboard</h1>
  </div>
  <div class="sidebar-subjects">
    <div class="sidebar-label">Subjects</div>
    <div id="subjectList"></div>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-subject" id="topbarSubject">Select a Subject</div>
      <div class="topbar-badge" id="topbarBadge">IGCSE</div>
    </div>
    <div class="topbar-right" id="clockDisplay"></div>
  </div>

  <div class="content" id="mainContent">
    <div class="empty-state">
      <div class="big">📚</div>
      <p>Pick a subject from the sidebar to start studying.<br>Each subject has its own independent timer.</p>
    </div>
  </div>
</div>

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toastContainer"></div>

<script>
// ─── CONFIG ───
const USER = "Vivan";
const SUBJECTS = ["Physics","Chemistry","Maths","English","Computer Science","Business","Economics","French"];
const WEAK_SUBJECTS = ["Chemistry","Computer Science","Business"];

const SYLLABUS = {
  Physics:          ["Motion & Forces","Energy","Electricity","Waves","Thermal Physics","Magnetism","Nuclear Physics"],
  Chemistry:        ["Atomic Structure","Bonding","Stoichiometry","Acids & Bases","Organic Chemistry","Electrochemistry","Rates of Reaction"],
  Maths:            ["Algebra","Geometry","Probability","Trigonometry","Statistics","Number Theory","Functions"],
  English:          ["Comprehension","Narrative Writing","Descriptive Writing","Summary Skills","Poetry Analysis","Directed Writing"],
  "Computer Science":["Binary & Hex","Logic Gates","Algorithms","Flowcharts","Data Representation","Networking","Databases"],
  Business:         ["Marketing","Finance","Operations","Human Resources","Business Objectives","Market Research","Strategy"],
  Economics:        ["Demand & Supply","Inflation","Market Structures","Government Policy","International Trade","Economic Development"],
  French:           ["Grammar","Vocabulary","Listening Skills","Writing","Speaking","Reading Comprehension"]
};

const TIPS = {
  Physics:    ["Draw free-body diagrams for every force question","Memorise SUVAT equations — they cover 40% of mechanics"],
  Chemistry:  ["Balance equations atom-by-atom, not by guessing","Moles = mass ÷ Mr — practise this daily"],
  Maths:      ["Show all working — method marks save grades","Sketch graphs before solving algebraically"],
  English:    ["Use PEE structure: Point → Evidence → Explain","Read the passage twice before answering"],
  "Computer Science":["Trace tables are often exam questions — practise them","Use pseudocode, not Python, in exams"],
  Business:   ["Always apply concepts to the context given","SWOT analysis appears in almost every paper"],
  Economics:  ["Draw supply/demand diagrams for every question","Know the difference between movements vs. shifts"],
  French:     ["Practise past tense alongside present","Learn connectives to boost writing marks"]
};

// ─── STATE ───
function defaultSubjectState() {
  return {
    sessions: [],        // [{minutes, date, timestamp}]
    remaining: 0,        // seconds left on current timer
    totalSet: 0,         // original seconds set
    isRunning: false
  };
}

function loadData() {
  try {
    const raw = localStorage.getItem("igcse_" + USER);
    if (!raw) return buildFresh();
    const d = JSON.parse(raw);
    // Ensure all subjects exist
    SUBJECTS.forEach(s => { if (!d[s]) d[s] = defaultSubjectState(); });
    return d;
  } catch(e) { return buildFresh(); }
}

function buildFresh() {
  const d = {};
  SUBJECTS.forEach(s => { d[s] = defaultSubjectState(); });
  return d;
}

let data = loadData();
let currentSubject = null;
let timerIntervals = {}; // one interval per subject that's running

function save() {
  localStorage.setItem("igcse_" + USER, JSON.stringify(data));
}

// ─── CLOCK ───
function updateClock() {
  const now = new Date();
  const h = String(now.getHours()).padStart(2,"0");
  const m = String(now.getMinutes()).padStart(2,"0");
  const s = String(now.getSeconds()).padStart(2,"0");
  const el = document.getElementById("clockDisplay");
  if (el) el.textContent = `${h}:${m}:${s}`;
}
setInterval(updateClock, 1000);
updateClock();

// ─── TOAST ───
function toast(msg, type="info") {
  const c = document.getElementById("toastContainer");
  const t = document.createElement("div");
  t.className = `toast ${type}`;
  t.innerHTML = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}

// ─── SIDEBAR ───
function renderSidebar() {
  const list = document.getElementById("subjectList");
  list.innerHTML = "";
  SUBJECTS.forEach(sub => {
    const btn = document.createElement("button");
    btn.className = "subject-btn no-select" + (currentSubject === sub ? " active" : "");
    if (data[sub].isRunning) btn.classList.add("running");

    const isWeak = WEAK_SUBJECTS.includes(sub);
    const badge = formatTime(data[sub].remaining);

    btn.innerHTML = `
      <span class="sub-name">
        ${isWeak ? '<span class="weak-dot"></span>' : ''}
        ${sub}
      </span>
      <span class="sub-timer-badge">${data[sub].isRunning ? badge : (data[sub].remaining > 0 ? badge : "–")}</span>
    `;
    btn.dataset.subject = sub;
    btn.addEventListener("click", () => selectSubject(sub));
    list.appendChild(btn);
  });
}

// ─── SELECT SUBJECT ───
function selectSubject(sub) {
  currentSubject = sub;

  const topbarSub = document.getElementById("topbarSubject");
  const topbarBadge = document.getElementById("topbarBadge");
  topbarSub.textContent = sub;
  topbarBadge.textContent = WEAK_SUBJECTS.includes(sub) ? "⚠ WEAK" : "IGCSE";
  topbarBadge.className = "topbar-badge" + (WEAK_SUBJECTS.includes(sub) ? " weak" : "");

  renderSidebar();
  renderMain();
}

// ─── MAIN CONTENT ───
function renderMain() {
  const content = document.getElementById("mainContent");
  if (!currentSubject) {
    content.innerHTML = `<div class="empty-state"><div class="big">📚</div><p>Pick a subject from the sidebar to start studying.</p></div>`;
    return;
  }

  content.innerHTML = `
    <div class="card timer-card">
      <div class="card-label">Pomodoro Timer</div>
      <div class="timer-display ${data[currentSubject].isRunning ? 'running' : (data[currentSubject].remaining > 0 ? 'paused' : '')}" id="timerDisplay">${formatTime(data[currentSubject].remaining)}</div>
      <div class="timer-progress-bar">
        <div class="timer-progress-fill ${data[currentSubject].isRunning ? 'running' : ''}" id="progressFill" style="width:${getProgressPct()}%"></div>
      </div>
      <div class="timer-controls">
        <input type="number" class="timer-input" id="setMinutes" placeholder="min" min="1" max="180" value="">
        <span class="timer-input-label">min</span>
        <button class="btn btn-primary" onclick="startTimer()">▶ Start</button>
        <button class="btn" onclick="pauseTimer()">⏸ Pause</button>
        <button class="btn btn-danger" onclick="resetTimer()">↺ Reset</button>
      </div>
      <div class="timer-stats">
        <div class="timer-stat">
          <div class="timer-stat-val" id="weeklyMin">0</div>
          <div class="timer-stat-lbl">Weekly mins</div>
        </div>
        <div class="timer-stat">
          <div class="timer-stat-val" id="sessionCount">0</div>
          <div class="timer-stat-lbl">Sessions</div>
        </div>
        <div class="timer-stat">
          <div class="timer-stat-val" id="todayMin">0</div>
          <div class="timer-stat-lbl">Today mins</div>
        </div>
        <div class="timer-stat">
          <div class="timer-stat-val" id="totalMin">0</div>
          <div class="timer-stat-lbl">All-time mins</div>
        </div>
      </div>
    </div>

    <div class="card ai-card">
      <div class="card-label">AI Recommendation</div>
      <div id="aiBox"></div>
    </div>

    <div class="card chart-card">
      <div class="card-label">Weekly Study Minutes (All Subjects)</div>
      <canvas id="weeklyChart" height="160"></canvas>
    </div>

    <div class="card heatmap-card">
      <div class="card-label">Study Heatmap — Last 42 Days</div>
      <div class="heatmap" id="heatmap"></div>
      <div class="heatmap-legend">
        <span>Less</span>
        <span class="sq hm-0" style="background:#0d1420;border:1px solid #1a2540"></span>
        <span class="sq hm-1"></span>
        <span class="sq hm-2"></span>
        <span class="sq hm-3"></span>
        <span class="sq hm-4"></span>
        <span>More</span>
      </div>
    </div>
  `;

  updateTimerStats();
  generateAI();
  renderWeeklyChart();
  renderHeatmap();
}

// ─── TIMER HELPERS ───
function formatTime(secs) {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return `${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`;
}

function getProgressPct() {
  const sub = data[currentSubject];
  if (!sub.totalSet || sub.totalSet === 0) return 0;
  return Math.round(((sub.totalSet - sub.remaining) / sub.totalSet) * 100);
}

// ─── TIMER ACTIONS ───
function startTimer() {
  if (!currentSubject) return;
  const sub = data[currentSubject];

  // If no time is set, read from input
  if (sub.remaining === 0) {
    const mins = parseInt(document.getElementById("setMinutes").value);
    if (!mins || mins <= 0) { toast("Enter a duration in minutes first!", "warning"); return; }
    sub.remaining = mins * 60;
    sub.totalSet = mins * 60;
  }

  if (sub.remaining <= 0) { toast("Timer already at 0. Reset first.", "warning"); return; }
  if (sub.isRunning) return;

  sub.isRunning = true;
  save();
  renderSidebar();

  timerIntervals[currentSubject] = setInterval(() => {
    tickTimer(currentSubject);
  }, 1000);

  updateTimerDisplay();
  toast(`Started ${currentSubject} — ${formatTime(sub.remaining)}`, "info");
}

function tickTimer(sub) {
  if (!data[sub].isRunning) {
    clearInterval(timerIntervals[sub]);
    return;
  }

  data[sub].remaining--;

  if (data[sub].remaining <= 0) {
    data[sub].remaining = 0;
    data[sub].isRunning = false;
    clearInterval(timerIntervals[sub]);
    delete timerIntervals[sub];
    logSession(sub);
    save();
    renderSidebar();
    if (sub === currentSubject) {
      updateTimerDisplay();
      toast(`🎉 Session complete for ${sub}!`, "success");
    }
    return;
  }

  save();
  renderSidebar();
  if (sub === currentSubject) updateTimerDisplay();
}

function pauseTimer() {
  if (!currentSubject) return;
  const sub = data[currentSubject];
  if (!sub.isRunning) return;
  sub.isRunning = false;
  clearInterval(timerIntervals[currentSubject]);
  delete timerIntervals[currentSubject];
  save();
  renderSidebar();
  updateTimerDisplay();
  toast(`Paused ${currentSubject}`, "info");
}

function resetTimer() {
  if (!currentSubject) return;
  const sub = data[currentSubject];
  sub.isRunning = false;
  sub.remaining = 0;
  sub.totalSet = 0;
  clearInterval(timerIntervals[currentSubject]);
  delete timerIntervals[currentSubject];
  save();
  renderSidebar();
  updateTimerDisplay();
}

function updateTimerDisplay() {
  if (!currentSubject) return;
  const sub = data[currentSubject];

  const display = document.getElementById("timerDisplay");
  const fill = document.getElementById("progressFill");
  if (!display) return;

  display.textContent = formatTime(sub.remaining);
  display.className = "timer-display" + (sub.isRunning ? " running" : (sub.remaining > 0 ? " paused" : ""));

  if (fill) {
    fill.style.width = getProgressPct() + "%";
    fill.className = "timer-progress-fill" + (sub.isRunning ? " running" : "");
  }

  updateTimerStats();
}

// ─── LOG SESSION ───
function logSession(sub) {
  const totalSet = data[sub].totalSet;
  const minutesStudied = totalSet > 0 ? Math.round(totalSet / 60) : 1;

  data[sub].sessions.push({
    minutes: minutesStudied,
    date: new Date().toDateString(),
    timestamp: Date.now()
  });

  data[sub].remaining = 0;
  data[sub].totalSet = 0;
  save();

  if (sub === currentSubject) {
    updateTimerStats();
    renderWeeklyChart();
    renderHeatmap();
    generateAI();
  }
}

// ─── TIMER STATS ───
function updateTimerStats() {
  if (!currentSubject) return;
  const sessions = data[currentSubject].sessions;
  const now = new Date();
  const today = now.toDateString();
  const weekAgo = new Date(); weekAgo.setDate(now.getDate() - 7);

  let weekly = 0, todayMins = 0, total = 0;
  sessions.forEach(s => {
    total += s.minutes;
    if (new Date(s.date) >= weekAgo) weekly += s.minutes;
    if (s.date === today) todayMins += s.minutes;
  });

  const el = id => document.getElementById(id);
  if (el("weeklyMin")) el("weeklyMin").textContent = weekly;
  if (el("sessionCount")) el("sessionCount").textContent = sessions.length;
  if (el("todayMin")) el("todayMin").textContent = todayMins;
  if (el("totalMin")) el("totalMin").textContent = total;
}

// ─── AI RECOMMENDATION ───
function generateAI() {
  const box = document.getElementById("aiBox");
  if (!box || !currentSubject) return;

  const sub = currentSubject;
  const sessions = data[sub].sessions.length;
  const topics = SYLLABUS[sub];
  const nextTopic = topics[sessions % topics.length];
  const isWeak = WEAK_SUBJECTS.includes(sub);

  // Pick a tip
  const tipList = TIPS[sub] || ["Review your notes and past papers!"];
  const tip = tipList[sessions % tipList.length];

  // Study streak
  const streak = calcStreak();

  let html = "";

  if (isWeak) {
    html += `<div class="ai-warning">⚠ Weak subject — schedule extra sessions and past paper practice</div>`;
  }

  html += `<div style="margin-bottom:8px;font-size:13px;color:#94a3b8;">Next recommended topic:</div>`;
  html += `<div class="ai-topic">📖 ${nextTopic}</div>`;

  html += `<div class="ai-tip">💡 ${tip}</div>`;

  if (streak > 0) {
    html += `<div style="margin-top:10px;font-size:12px;color:#4ade80;">🔥 Study streak: ${streak} day${streak > 1 ? "s" : ""} in a row</div>`;
  }

  if (sessions === 0) {
    html += `<div style="margin-top:8px;font-size:12px;color:#64748b;">No sessions logged yet. Start your first session!</div>`;
  } else if (sessions < 3) {
    html += `<div style="margin-top:8px;font-size:12px;color:#64748b;">Keep going — consistency beats cramming every time.</div>`;
  } else {
    html += `<div style="margin-top:8px;font-size:12px;color:#64748b;">${sessions} session${sessions > 1 ? "s" : ""} logged. Excellent discipline.</div>`;
  }

  box.innerHTML = html;
}

function calcStreak() {
  // Count consecutive days (across all subjects) that had at least one session
  const allDates = new Set();
  SUBJECTS.forEach(sub => {
    data[sub].sessions.forEach(s => allDates.add(s.date));
  });

  let streak = 0;
  const now = new Date();
  for (let i = 0; i < 365; i++) {
    const d = new Date(now);
    d.setDate(now.getDate() - i);
    if (allDates.has(d.toDateString())) {
      streak++;
    } else {
      break;
    }
  }
  return streak;
}

// ─── WEEKLY CHART ───
let weeklyChart = null;
function renderWeeklyChart() {
  const canvas = document.getElementById("weeklyChart");
  if (!canvas) return;

  const days = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
  const dayData = new Array(7).fill(0);
  const weekAgo = new Date(); weekAgo.setDate(new Date().getDate() - 7);

  SUBJECTS.forEach(sub => {
    data[sub].sessions.forEach(s => {
      const d = new Date(s.date);
      if (d >= weekAgo) dayData[d.getDay()] += s.minutes;
    });
  });

  if (weeklyChart) { weeklyChart.destroy(); weeklyChart = null; }

  weeklyChart = new Chart(canvas, {
    type: "bar",
    data: {
      labels: days,
      datasets: [{
        label: "Minutes",
        data: dayData,
        backgroundColor: dayData.map(v => v > 0 ? "#3b82f6" : "#1a2540"),
        borderColor: dayData.map(v => v > 0 ? "#60a5fa" : "#1a2540"),
        borderWidth: 1,
        borderRadius: 6,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: "#1a2540" }, ticks: { color: "#64748b", font: { family: "'Space Mono'" } } },
        y: { grid: { color: "#1a2540" }, ticks: { color: "#64748b", font: { family: "'Space Mono'" } }, beginAtZero: true }
      }
    }
  });
}

// ─── HEATMAP ───
function renderHeatmap() {
  const heat = document.getElementById("heatmap");
  if (!heat) return;
  heat.innerHTML = "";

  const counts = {};
  SUBJECTS.forEach(sub => {
    data[sub].sessions.forEach(s => {
      counts[s.date] = (counts[s.date] || 0) + s.minutes;
    });
  });

  // Build 42 squares oldest→newest
  const squares = [];
  for (let i = 41; i >= 0; i--) {
    const d = new Date();
    d.setDate(d.getDate() - i);
    squares.push(d);
  }

  squares.forEach(d => {
    const key = d.toDateString();
    const mins = counts[key] || 0;
    const sq = document.createElement("div");
    sq.className = "hm-square";

    let lvl = 0;
    if (mins > 0) lvl = 1;
    if (mins > 60) lvl = 2;
    if (mins > 120) lvl = 3;
    if (mins > 200) lvl = 4;

    sq.classList.add("hm-" + lvl);
    sq.title = `${d.toLocaleDateString("en-GB", {day:"numeric",month:"short"})}: ${mins} min`;
    heat.appendChild(sq);
  });
}

// ─── RESUME RUNNING TIMERS ───
// If page was closed with a running timer, calculate elapsed and update
function resumeTimers() {
  SUBJECTS.forEach(sub => {
    if (data[sub].isRunning) {
      // Just restart the interval — we can't know how long the page was closed
      // so we keep remaining as-is (no background ticking when page is closed)
      data[sub].isRunning = false; // reset so user has to manually resume
      save();
    }
  });
}
resumeTimers();

// ─── INIT ───
renderSidebar();
</script>

